{
  "training": {
    "wandb_project": "cheetah_ft_latent",
    "seed": 44,
    "save_dir": "./data/models/cheetah_tdmpc2_loraxs",

    "checkpoint_enabled": true,
    "checkpoint_freq": 100000,
    "num_agents": 1,
    "max_steps": 1000000,
    "buffer_size": 1000010,
    "dim_state": 17,
    "dim_action": 6,
    "eval_freq": 10000,
    "chunk_size": 1000,
    "plot_eval": false,

    "visualizer": {
      "type": "cheetah"
    },

    "evaluator": {
      "seed": 123,
      "max_steps": 500,
      "num_episodes": 2,
      "environment": {},
      "planner": {"type": "mppi"}
    },

    "normalizer": {
      "critic": {
        "q_scale_init": 1.0
      }
    },

    "encoder": {
      "type": "proprioceptive",
      "encoder_features": [256, 128, 64],
      "simnorm_dim_v": 8,
      "simnorm_tau": 1.0,
      "frozen": false
    },

    "dynamics": {
      "type": "dense_lora_xs",
      "dynamics_features": [512, 512, 128, 64],
      "simnorm_dim_v": 8,
      "simnorm_tau": 1.0,
      "rank": 48,
      "r_init_std": 1e-5,
      "adapt_layers": [0, 1, 2, 3],
      "frozen_backbone": false,
      "frozen_adapter": false,
      "freeze_subspace": false
    },

    "critic": {
      "type": "ensemble",
      "features": [512, 512],
      "num_ensemble": 5,
      "num_bins": 101,
      "vmin": -10.0,
      "vmax": 10.0,
      "dropout": 0.01,
      "num_subsample": 2,
      "frozen": false
    },

    "policy": {
      "type": "squashed_gaussian",
      "features": [512, 512],
      "log_std_min": -10,
      "log_std_max": 2,
      "frozen": false
    },

    "reward": {
      "type": "mlp",
      "features": [512, 512],
      "num_bins": 101,
      "vmin": -10.0,
      "vmax": 10.0,
      "frozen": false
    },

    "environment": {
      "type": "cheetah",
      "num_agents": 1,
      "max_episode_steps": 500,
      "cheetah_mass_scale": 1.0
    },

    "trainer": {
      "type": "tdmpc2",
      "lr": 3e-4,
      "encoder_lr": 1e-4,
      "policy_lr": 3e-4,
      "grad_clip_norm": 20,
      "horizon": 3,
      "discount_factor": 0.99,
      "temporal_decay": 0.5,
      "ema_decay": 0.99,
      "consistency_coef": 20.0,
      "reward_coef": 0.1,
      "value_coef": 0.1,
      "entropy_coef": 1e-4
    },

    "sampler": {
      "type": "trajectory_batch",
      "batch_size": 256,
      "horizon": 3,
      "min_buffer_size": 2500
    },

    "state_labels": [
      "rootz", "rooty", "bthigh", "bshin", "bfoot", "fthigh", "fshin", "ffoot",
      "vel_x", "vel_z", "vel_y", "vel_bthigh", "vel_bshin", "vel_bfoot",
      "vel_fthigh", "vel_fshin", "vel_ffoot"
    ],

    "planner": {
      "type": "mppi",
      "info_weight": 0.0,
      "info_horizon": 1,
      "meas_noise_scale": 1.0,
      "horizon": 3,
      "num_iterations": 6,
      "dim_control": 6,
      "batch_size": 512,
      "num_pi_trajs": 24,
      "temperature": 0.5,
      "min_std": 0.05,
      "discount_factor": 0.99,
      "num_elites": 64,
      "max_std": 2.0
    }
  }
}
