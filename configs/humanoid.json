{
  "training": {
    "wandb_project": "tdmpc2-humanoid",
    "seed": 43,
    "save_dir": "./data/models/humanoid",
    "checkpoint_enabled": true,
    "checkpoint_freq": 100000,
    "num_agents": 1,
    "max_steps": 100000,
    "buffer_size": 1000010,
    "dim_state": 46,
    "dim_action": 17,
    "eval_freq": 10000,
    "chunk_size": 1,
    "plot_eval": true,

    "visualizer": {
      "type": "humanoid"
    },

    "evaluator": {
      "seed": 123,
      "max_steps": 500,
      "num_episodes": 5,
      "environment": {},
      "planner": {}
    },

    "normalizer": {
      "critic": {
        "q_scale_init": 1.0
      }
    },

    "encoder": {
      "type": "proprioceptive",
      "encoder_features": [256, 128, 64],
      "simnorm_dim_v": 8,
      "simnorm_tau": 1.0,
      "frozen": false
    },

    "dynamics": {
      "type": "dense_last_layer",
      "dynamics_features": [512, 512, 256, 128],
      "simnorm_dim_v": 8,
      "simnorm_tau": 1.0,
      "svd_rank": 64,
      "r_init_std": 1e-5,
      "frozen": false
    },

    "critic": {
      "type": "ensemble",
      "features": [512, 512],
      "num_ensemble": 5,
      "num_bins": 101,
      "vmin": -10.0,
      "vmax": 10.0,
      "dropout": 0.01,
      "num_subsample": 2,
      "frozen": false
    },

    "policy": {
      "type": "squashed_gaussian",
      "features": [512, 512],
      "log_std_min": -10,
      "log_std_max": 2,
      "frozen": false
    },

    "reward": {
      "type": "mlp",
      "features": [512, 512],
      "num_bins": 101,
      "vmin": -10.0,
      "vmax": 10.0,
      "frozen": false
    },

    "environment": {
      "type": "humanoid",
      "num_agents": 1,
      "max_episode_steps": 500,
      "humanoid_mass_scale": 1.0
    },

    "trainer": {
      "type": "ogd",
      "lr": 3e-4,
      "encoder_lr": 3e-4,
      "policy_lr": 3e-4,
      "grad_clip_norm": 20,
      "horizon": 1,
      "discount_factor": 0.99,
      "temporal_decay": 0.5,
      "ema_decay": 0.99,
      "consistency_coef": 20.0,
      "reward_coef": 0.1,
      "value_coef": 0.1,
      "entropy_coef": 1e-4
    },

    "sampler": {
      "type": "trajectory_batch",
      "batch_size": 256,
      "horizon": 3,
      "min_buffer_size": 259
    },

    "state_labels": [
      "root_z", "root_y", "root_x_vel", "root_y_vel", "root_z_vel", "root_y_omega",
      "chest_y", "chest_z", "neck_y", "neck_z",
      "right_shoulder1", "right_shoulder2", "right_elbow",
      "left_shoulder1", "left_shoulder2", "left_elbow",
      "right_hip_x", "right_hip_z", "right_knee", "right_ankle",
      "left_hip_x", "left_hip_z", "left_knee", "left_ankle",
      "vel_chest_y", "vel_chest_z", "vel_neck_y", "vel_neck_z",
      "vel_right_shoulder1", "vel_right_shoulder2", "vel_right_elbow",
      "vel_left_shoulder1", "vel_left_shoulder2", "vel_left_elbow",
      "vel_right_hip_x", "vel_right_hip_z", "vel_right_knee", "vel_right_ankle",
      "vel_left_hip_x", "vel_left_hip_z", "vel_left_knee", "vel_left_ankle"
    ],

    "planner": {
      "type": "mppi",
      "horizon": 3,
      "num_iterations": 6,
      "dim_control": 17,
      "batch_size": 512,
      "num_pi_trajs": 24,
      "temperature": 0.5,
      "min_std": 0.05,
      "discount_factor": 0.99,
      "num_elites": 64,
      "max_std": 2.0
    }

  }
}
