{
  "training": {
    "wandb_project": "finetune-quadruped-dmcontrol",
    "seed": 43,
    "save_dir": "./data/models/quadruped",
    "pretrained_path": null,
    "checkpoint_enabled": true,
    "checkpoint_freq": 100000,
    "num_agents": 1,
    "max_steps": 100000,
    "buffer_size": 1000010,
    "dim_state": 36,
    "dim_action": 10,
    "eval_freq": 10000,
    "chunk_size": 1,
    "plot_eval": true,

    "visualizer": {
      "type": "quadruped"
    },

    "evaluator": {
      "seed": 123,
      "max_steps": 1000,
      "num_episodes": 5,
      "environment": {},
      "planner": {}
    },

    "normalizer": {
      "critic": {
        "q_scale_init": 1.0
      }
    },

    "encoder": {
      "type": "proprioceptive",
      "encoder_features": [256, 128, 64],
      "simnorm_dim_v": 8,
      "simnorm_tau": 1.0,
      "frozen": false
    },

    "dynamics": {
      "type": "dense_last_layer",
      "dynamics_features": [512, 512, 128, 64],
      "simnorm_dim_v": 8,
      "simnorm_tau": 1.0,
      "svd_rank": 48,
      "r_init_std": 1e-5,
      "frozen": false
    },

    "critic": {
      "type": "ensemble",
      "features": [512, 512],
      "num_ensemble": 5,
      "num_bins": 101,
      "vmin": -10.0,
      "vmax": 10.0,
      "dropout": 0.01,
      "num_subsample": 2,
      "frozen": false
    },

    "policy": {
      "type": "squashed_gaussian",
      "features": [512, 512],
      "log_std_min": -10,
      "log_std_max": 2,
      "frozen": false
    },

    "reward": {
      "type": "mlp",
      "features": [512, 512],
      "num_bins": 101,
      "vmin": -10.0,
      "vmax": 10.0,
      "frozen": false
    },

    "environment": {
      "type": "quadruped",
      "num_agents": 1,
      "max_episode_steps": 1000
    },

    "trainer": {
      "type": "ogd",
      "lr": 3e-4,
      "encoder_lr": 3e-4,
      "policy_lr": 3e-4,
      "grad_clip_norm": 20,
      "horizon": 1,
      "discount_factor": 0.99,
      "temporal_decay": 0.5,
      "ema_decay": 0.99,
      "consistency_coef": 20.0,
      "reward_coef": 0.1,
      "value_coef": 0.1,
      "entropy_coef": 1e-4
    },

    "sampler": {
      "type": "trajectory_batch",
      "batch_size": 256,
      "horizon": 3,
      "min_buffer_size": 259
    },

    "state_labels": [
      "torso_height", "torso_pitch", "torso_roll",
      "back_thigh_joint", "back_shin_joint", "back_foot_joint",
      "front_thigh_joint", "front_shin_joint", "front_foot_joint",
      "torso_angular_velocity_x", "torso_angular_velocity_y", "torso_angular_velocity_z",
      "torso_linear_velocity_x", "torso_linear_velocity_y", "torso_linear_velocity_z",
      "back_thigh_velocity", "back_shin_velocity", "back_foot_velocity",
      "front_thigh_velocity", "front_shin_velocity", "front_foot_velocity",
      "back_leg_contact", "front_leg_contact",
      "joint_angles_1", "joint_angles_2", "joint_angles_3", "joint_angles_4", "joint_angles_5",
      "joint_velocities_1", "joint_velocities_2", "joint_velocities_3", "joint_velocities_4", "joint_velocities_5",
      "contact_info_1", "contact_info_2", "contact_info_3", "contact_info_4"
    ],

    "planner": {
      "type": "mppi",
      "horizon": 3,
      "num_iterations": 6,
      "dim_control": 10,
      "batch_size": 512,
      "num_pi_trajs": 24,
      "temperature": 0.5,
      "min_std": 0.05,
      "discount_factor": 0.99,
      "num_elites": 64,
      "max_std": 2.0
    }

  }
}
