{
  "training": {
    "wandb_project": "meta_lora_streaming",
    "seed": 44,
    "num_seeds": 3,
    "num_processes": 2,
    "save_dir": "./data/models/stream_gd_loraxs_maml",
    "pretrained_path": "/home/fp5275/repos/max/data/models/cheetah_maml/20260416_123526/step_200000.pkl",
    "checkpoint_enabled": false,
    "num_agents": 1,
    "max_steps": 10000,
    "buffer_size": 10000,
    "dim_state": 17,
    "dim_action": 6,
    "eval_freq": 1000,
    "chunk_size": 1,
    "plot_eval": true,

    "visualizer": {
      "type": "cheetah"
    },

    "evaluator": {
      "seed": 123,
      "max_steps": 500,
      "num_episodes": 2,
      "environment": { "cheetah_mass_scale": 0.5 },
      "planner": { "type": "mppi" }
    },

    "normalizer": {
      "critic": { "q_scale_init": 1.0 }
    },

    "encoder": {
      "type": "proprioceptive",
      "encoder_features": [256, 128, 64],
      "simnorm_dim_v": 8,
      "simnorm_tau": 1.0,
      "frozen": true
    },

    "dynamics": {
      "type": "dense_lora_xs",
      "dynamics_features": [512, 512, 128, 64],
      "simnorm_dim_v": 8,
      "simnorm_tau": 1.0,
      "rank": 48,
      "r_init_std": 1e-5,
      "adapt_layers": [0, 1, 2, 3],
      "frozen_backbone": true,
      "frozen_adapter": false,
      "freeze_subspace": true
    },

    "critic": {
      "type": "ensemble",
      "features": [512, 512],
      "num_ensemble": 5,
      "num_bins": 101,
      "vmin": -10.0,
      "vmax": 10.0,
      "dropout": 0.01,
      "num_subsample": 2,
      "frozen": true
    },

    "policy": {
      "type": "squashed_gaussian",
      "features": [512, 512],
      "log_std_min": -10,
      "log_std_max": 2,
      "frozen": true
    },

    "reward": {
      "type": "mlp",
      "features": [512, 512],
      "num_bins": 101,
      "vmin": -10.0,
      "vmax": 10.0,
      "frozen": true
    },

    "environment": {
      "type": "cheetah",
      "num_agents": 1,
      "max_episode_steps": 500,
      "cheetah_mass_scale": 0.5
    },

    "trainer": {
      "type": "gd_lora_xs",
      "meta_lr_inner": 4e-5
    },

    "sampler": {
      "type": "latest",
      "batch_size": 1,
      "horizon": 1,
      "min_buffer_size": 1
    },

    "state_labels": [
      "rootz", "rooty", "bthigh", "bshin", "bfoot", "fthigh", "fshin", "ffoot",
      "vel_x", "vel_z", "vel_y", "vel_bthigh", "vel_bshin", "vel_bfoot",
