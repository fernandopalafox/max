      "meas_noise_scale": 1.0,
      "horizon": 3,
      "num_iterations": 6,
      "dim_control": 6,
      "batch_size": 512,
      "num_pi_trajs": 24,
      "temperature": 0.5,
      "min_std": 0.05,
      "discount_factor": 0.99,
      "num_elites": 64,
      "max_std": 2.0
    }
