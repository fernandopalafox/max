{
  "training": {
    "wandb_project": "finetune-cheetah",
    "seed": 43,
    "save_dir": "/home/fp5275/repos/max/data/models/cheetah",
    "pretrained_path": "/home/fp5275/repos/max/data/models/cheetah/20260323_less_features/final.pkl",
    "checkpoint_enabled": true,
    "checkpoint_freq": 100000,
    "num_agents": 1,
    "max_steps": 1000000,
    "buffer_size": 1000010,
    "dim_state": 17,
    "dim_action": 6,
    "train_freq": 1000000,
    "eval_freq": 10000,
    "chunk_size": 1,
    "plot_eval": true,

    "evaluator": {
      "seed": 123,
      "max_steps": 500,
      "num_episodes": 10,
      "environment": {},
      "planner": {}
    },

    "normalizer": {
      "critic": {
        "q_scale_init": 1.0
      }
    },

    "encoder": {
      "type": "proprioceptive",
      "encoder_features": [256, 128, 64],
      "simnorm_dim_v": 8,
      "simnorm_tau": 1.0,
      "frozen": true
    },

    "dynamics": {
      "type": "dense_last_layer",
      "dynamics_features": [512, 512, 128, 64],
      "simnorm_dim_v": 8,
      "simnorm_tau": 1.0,
      "frozen": false
    },

    "critic": {
      "type": "ensemble",
      "features": [512, 512],
      "num_ensemble": 5,
      "num_bins": 101,
      "vmin": -10.0,
      "vmax": 10.0,
      "dropout": 0.01,
      "num_subsample": 2,
      "frozen": true
    },

    "policy": {
      "type": "squashed_gaussian",
      "features": [512, 512],
      "log_std_min": -10,
      "log_std_max": 2,
      "frozen": true
    },

    "reward": {
      "type": "mlp",
      "features": [512, 512],
      "num_bins": 101,
      "vmin": -10.0,
      "vmax": 10.0,
      "frozen": true
    },

    "environment": {
      "type": "cheetah",
      "num_agents": 1,
      "max_episode_steps": 500,
      "cheetah_mass_scale": 1.0
    },

    "trainer": {
      "type": "ogd",
      "lr": 3e-4,
      "encoder_lr": 9e-5,
      "policy_lr": 3e-4,
      "grad_clip_norm": 20,
      "horizon": 1,
      "discount_factor": 0.99,
      "temporal_decay": 0.5,
      "ema_decay": 0.99,
      "consistency_coef": 20.0,
      "reward_coef": 0.1,
      "value_coef": 0.1,
      "entropy_coef": 1e-4
    },

    "sampler": {
      "type": "latest",
      "batch_size": 1,
      "horizon": 1,
      "min_buffer_size": 0
    },

    "state_labels": [
      "rootz", "rooty", "bthigh", "bshin", "bfoot", "fthigh", "fshin", "ffoot",
      "vel_x", "vel_z", "vel_y", "vel_bthigh", "vel_bshin", "vel_bfoot",
      "vel_fthigh", "vel_fshin", "vel_ffoot"
    ],

    "planner": {
      "type": "mppi",
      "horizon": 3,
      "num_iterations": 6,
      "dim_control": 6,
      "batch_size": 512,
      "num_pi_trajs": 24,
      "temperature": 0.5,
      "min_std": 0.05,
      "discount_factor": 0.99,
      "num_elites": 64,
      "max_std": 2.0
    }

  }
}
