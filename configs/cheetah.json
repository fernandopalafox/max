{
  "pretraining": {
    "seed": 42,
    "wandb_project": "cheetah_pretraining",
    "data_path": "./data/cheetah_data/cheetah_run_tdmpc2_clean_small_aug.pkl",
    "save_path": "./data/pretrained_models/cheetah",

    "num_epochs": 1000,
    "batch_size": 256,
    "train_split": 0.8,

    "dim_state": 17,
    "dim_action": 6,

    "dynamics": "latent_dynamics",
    "dynamics_params": {
      "encoder_features": [256, 128],
      "dynamics_features": [512, 512, 128],
      "decoder_features": [512, 256],
      "simnorm_dim_v": 8,
      "simnorm_tau": 1.0,
      "pretrained_params_path": null
    },

    "trainer": "latent_gd",
    "trainer_params": {
      "learning_rate": 1e-4,
      "multistep_horizon": 5,
      "temporal_coefficient": 0.5
    },

    "checkpoint_enabled": true,
    "checkpoint_freq": 10,
    "eval_plot_freq": 20,
    "eval_rollout_steps": 50,
    "state_labels": ["rootz", "rooty", "bthigh", "bshin", "bfoot", "fthigh", "fshin", "ffoot",
                     "vel_x", "vel_z", "vel_y", "vel_bthigh", "vel_bshin", "vel_bfoot",
                     "vel_fthigh", "vel_fshin", "vel_ffoot"],

    "normalization": { "method": "static" },
    "normalization_params": {
      "state": {
        "min": [-1, -4, -1, -2, -2, -2, -2, -1, -4, -5, -10, -27, -33, -28, -19, -36, -25],
        "max": [1, 18, 2, 1, 1, 1, 2, 1, 13, 5, 15, 24, 30, 30, 29, 33, 29]
      },
      "action": {
        "min": [-1, -1, -1, -1, -1, -1],
        "max": [1, 1, 1, 1, 1, 1]
      },
      "delta": {
        "min": [-1, -17, -2, -1, -1, -1, -2, -1, -13, -4, -11, -28, -26, -34, -32, -30, -35],
        "max": [1, 4, 1, 2, 1, 2, 1, 1, 4, 8, 9, 25, 35, 30, 30, 34, 35]
      }
    }
  },

  "finetuning": {
    "wandb_project": "cheetah_ft_latent",
    "seed": 43,
    "save_dir": null,
    "plot_run": false,
    "plot_eval": true,
    "env_name": "cheetah",
    "num_agents": 1,
    "total_steps": 200000,
    "dim_state": 17,
    "dim_action": 6,
    "train_freq": 1,
    "normalize_freq": 1000000,
    "eval_freq": 300000,
    "buffer_size": 200010,

    "evaluator_params": {
      "seed": 123,
      "max_steps": 150,
      "num_episodes": 2,
      "env_params": {},
      "planner_params": {}
    },

    "encoder_params": {
      "encoder_features": [256, 128],
      "decoder_features": [512, 256],
      "simnorm_dim_v": 8,
      "simnorm_tau": 1.0
    },

    "dynamics": "dense",
    "dynamics_params": {
      "dynamics_features": [512, 512, 128],
      "simnorm_dim_v": 8,
      "simnorm_tau": 1.0
    },

    "critic_params": {
      "features": [512, 512],
      "num_ensemble": 5,
      "num_bins": 101,
      "vmin": -10.0,
      "vmax": 10.0,
      "dropout": 0.01,
      "num_subsample": 2
    },

    "policy_params": {
      "features": [512, 512],
      "log_std_min": -10,
      "log_std_max": 2
    },

    "reward_params": {
      "features": [512, 512],
      "num_bins": 101,
      "vmin": -10.0,
      "vmax": 10.0
    },

    "env_params": {
      "num_agents": 1,
      "max_episode_steps": 500,
      "cheetah_mass_scale": 1.0,
      "cheetah_n_substeps": 2
    },

    "trainer": "tdmpc2",
    "trainer_params": {
      "lr": 3e-4,
      "encoder_lr": 1e-4,
      "policy_lr": 3e-4,
      "grad_clip_norm": 20,
      "horizon": 3,
      "discount_factor": 0.99,
      "temporal_decay": 0.5,
      "ema_decay": 0.01,
      "consistency_coef": 20.0,
      "reward_coef": 0.1,
      "value_coef": 0.1,
      "entropy_coef": 1e-4
    },

    "sampler": {
      "type": "trajectory_batch",
      "batch_size": 256,
      "horizon": 3,
      "min_buffer_size": 259
    },

    "normalization": { "method": "static" },
    "normalization_params": {
        "state": {
        "min": [-1, -4, -1, -2, -2, -2, -2, -1, -4, -5, -10, -27, -33, -28, -19, -36, -25],
        "max": [1, 18, 2, 1, 1, 1, 2, 1, 13, 5, 15, 24, 30, 30, 29, 33, 29]
      },
      "action": {
        "min": [-1, -1, -1, -1, -1, -1],
        "max": [1, 1, 1, 1, 1, 1]
      },
      "delta": {
        "min": [-1, -17, -2, -1, -1, -1, -2, -1, -13, -4, -11, -28, -26, -34, -32, -30, -35],
        "max": [1, 4, 1, 2, 1, 2, 1, 1, 4, 8, 9, 25, 35, 30, 30, 34, 35]
      }
    },

    "state_labels": [
      "rootz", "rooty", "bthigh", "bshin", "bfoot", "fthigh", "fshin", "ffoot",
      "vel_x", "vel_z", "vel_y", "vel_bthigh", "vel_bshin", "vel_bfoot",
      "vel_fthigh", "vel_fshin", "vel_ffoot"
    ],

    "planner_type": "mppi",
    "planner_params": {
      "horizon": 3,
      "num_iterations": 6,
      "dim_control": 6,
      "batch_size": 512,
      "num_pi_trajs": 24,
      "temperature": 0.5,
      "min_std": 0.05,
      "discount_factor": 0.99,
      "num_elites": 64,
      "max_std": 2.0
    }

  }
}
